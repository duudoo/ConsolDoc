APP_NAME=ConsolDoc
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://consoldoc.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=consoldoc
DB_USERNAME=consoldoc
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

FILESYSTEM_DISK=local

# Google Document AI / AI Config
GOOGLE_APPLICATION_CREDENTIALS=/var/www/html/google-docai.json
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
